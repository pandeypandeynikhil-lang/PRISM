# PRISM v2 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── AI / LLM ──────────────────────────────────────────────
# Gemini (Primary) — free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Fallback) — free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Database ──────────────────────────────────────────────
# PostgreSQL (recommended for production)
# If your password contains @ encode it as %40  e.g. Pass@123 → Pass%40123
DATABASE_URL=postgresql+asyncpg://postgres:Rogernik%402803@127.0.0.1:5432/prism

# SQLite (fallback, no setup needed — remove the line above and uncomment below)
# DATABASE_URL=sqlite+aiosqlite:///./prism.db

# ── App Config ────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── CPI Model Weights (optional override) ─────────────────
# CPI = ALPHA*CRS + BETA*OS + GAMMA*IS  (must sum to 1.0)
CPI_ALPHA=0.5
CPI_BETA=0.3
CPI_GAMMA=0.2
